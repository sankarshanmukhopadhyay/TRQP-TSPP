{
  "$id": "https://example.org/schemas/tspp-trqp-metadata.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "assurance_level": {
      "description": "Declared assurance level for this TRQP deployment.",
      "enum": [
        "AL1",
        "AL2"
      ],
      "type": "string"
    },
    "audit": {
      "additionalProperties": false,
      "description": "Audit posture signals for AL3/AL4 deployments.",
      "properties": {
        "audit_log_uri": {
          "description": "URI to audit logging policy or immutable log endpoint (AL4+).",
          "format": "uri",
          "type": "string"
        },
        "immutability": {
          "description": "Audit log immutability posture.",
          "enum": [
            "none",
            "append-only",
            "immutable"
          ],
          "type": "string"
        },
        "independent_assessment_uri": {
          "description": "URI to independent assessment evidence (AL3+).",
          "format": "uri",
          "type": "string"
        },
        "retention_days": {
          "description": "Audit log retention.",
          "minimum": 1,
          "type": "integer"
        }
      },
      "type": "object"
    },
    "auth": {
      "additionalProperties": false,
      "properties": {
        "audience": {
          "description": "Expected token 'aud' value for this registry (recommended).",
          "maxLength": 2048,
          "minLength": 1,
          "type": "string"
        },
        "max_token_ttl_seconds": {
          "description": "Maximum acceptable token TTL in seconds. Recommended <= 900.",
          "maximum": 86400,
          "minimum": 1,
          "type": "integer"
        },
        "methods": {
          "description": "Supported authentication methods.",
          "items": {
            "enum": [
              "bearer",
              "mtls",
              "dpop"
            ],
            "type": "string"
          },
          "minItems": 1,
          "type": "array"
        },
        "required": {
          "description": "Whether authentication is required for query endpoints.",
          "type": "boolean"
        },
        "required_scopes": {
          "description": "Scopes enforced by the server.",
          "items": {
            "enum": [
              "trqp.authorization.query",
              "trqp.recognition.query"
            ],
            "type": "string"
          },
          "minItems": 1,
          "type": "array",
          "uniqueItems": true
        },
        "sender_constrained_required_for_bulk": {
          "default": false,
          "description": "If true, bulk clients must use sender-constrained tokens (mTLS/DPoP).",
          "type": "boolean"
        }
      },
      "required": [
        "required",
        "methods",
        "max_token_ttl_seconds",
        "required_scopes"
      ],
      "type": "object"
    },
    "context_allowlist": {
      "description": "Explicit list of accepted context keys. Unknown keys must be rejected or stripped.",
      "items": {
        "maxLength": 128,
        "minLength": 1,
        "type": "string"
      },
      "minItems": 0,
      "type": "array",
      "uniqueItems": true
    },
    "freshness": {
      "additionalProperties": false,
      "properties": {
        "default_expires_seconds": {
          "description": "Default validity window for responses.",
          "maximum": 31536000,
          "minimum": 1,
          "type": "integer"
        },
        "max_staleness_seconds": {
          "description": "Client-enforced maximum staleness for sensitive operations.",
          "maximum": 31536000,
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "max_staleness_seconds",
        "default_expires_seconds"
      ],
      "type": "object"
    },
    "governance": {
      "additionalProperties": false,
      "description": "Governance and change control signals for AL3/AL4 deployments.",
      "properties": {
        "change_control_uri": {
          "description": "Documented change control process for policy/config changes.",
          "format": "uri",
          "type": "string"
        },
        "policy_uri": {
          "description": "Canonical policy document/endpoint governing operations.",
          "format": "uri",
          "type": "string"
        },
        "rollback_uri": {
          "description": "Rollback policy/process for reverting changes.",
          "format": "uri",
          "type": "string"
        },
        "version": {
          "description": "Governance/policy version identifier.",
          "type": "string"
        }
      },
      "type": "object"
    },
    "key_protection": {
      "additionalProperties": false,
      "description": "Key protection claims for AL4+ deployments.",
      "properties": {
        "evidence_uri": {
          "description": "Evidence supporting key protection claims (e.g., attestation/report).",
          "format": "uri",
          "type": "string"
        },
        "protection": {
          "description": "Key storage/protection class.",
          "enum": [
            "software",
            "KMS",
            "HSM"
          ],
          "type": "string"
        }
      },
      "type": "object"
    },
    "monitoring": {
      "additionalProperties": false,
      "description": "Operational monitoring signals for AL4+ deployments.",
      "properties": {
        "evidence_retention_days": {
          "description": "Retention period for monitoring/audit evidence.",
          "minimum": 1,
          "type": "integer"
        },
        "incident_contact": {
          "description": "Incident contact channel for escalations.",
          "type": "string"
        },
        "runbook_uri": {
          "description": "Runbook URI for incident response / operations.",
          "format": "uri",
          "type": "string"
        }
      },
      "type": "object"
    },
    "namespacing": {
      "additionalProperties": false,
      "description": "Declares whether namespaced/versioned action/resource tokens are required.",
      "properties": {
        "action_required": {
          "type": "boolean"
        },
        "recommended_formats": {
          "items": {
            "enum": [
              "uri",
              "urn",
              "did-fragment"
            ],
            "type": "string"
          },
          "minItems": 1,
          "type": "array"
        },
        "resource_required": {
          "type": "boolean"
        },
        "versioning_required": {
          "type": "boolean"
        }
      },
      "required": [
        "action_required",
        "resource_required",
        "versioning_required"
      ],
      "type": "object"
    },
    "operator": {
      "additionalProperties": false,
      "description": "Optional operator metadata used for incident response and audit.",
      "properties": {
        "name": {
          "maxLength": 256,
          "minLength": 1,
          "type": "string"
        },
        "security_contact": {
          "additionalProperties": false,
          "properties": {
            "email": {
              "format": "email",
              "type": "string"
            },
            "url": {
              "format": "uri",
              "type": "string"
            }
          },
          "required": [
            "email"
          ],
          "type": "object"
        }
      },
      "required": [
        "name",
        "security_contact"
      ],
      "type": "object"
    },
    "profile": {
      "const": "TSPP-TRQP-0.1",
      "description": "Profile identifier.",
      "type": "string"
    },
    "rate_limits": {
      "additionalProperties": false,
      "description": "High-level rate limiting policy; detailed tiers may be described separately.",
      "properties": {
        "burst": {
          "maximum": 100000,
          "minimum": 0,
          "type": "integer"
        },
        "per_client_rps": {
          "maximum": 100000,
          "minimum": 1,
          "type": "integer"
        },
        "per_ip_rps": {
          "maximum": 100000,
          "minimum": 1,
          "type": "integer"
        }
      },
      "required": [
        "per_client_rps",
        "per_ip_rps",
        "burst"
      ],
      "type": "object"
    },
    "recognition_policy": {
      "additionalProperties": false,
      "properties": {
        "expiry_required": {
          "type": "boolean"
        },
        "max_chain_depth": {
          "maximum": 32,
          "minimum": 0,
          "type": "integer"
        },
        "scoped_required": {
          "type": "boolean"
        },
        "transitive_default": {
          "type": "boolean"
        }
      },
      "required": [
        "scoped_required",
        "expiry_required",
        "transitive_default",
        "max_chain_depth"
      ],
      "type": "object"
    },
    "signing": {
      "additionalProperties": false,
      "properties": {
        "algorithms": {
          "items": {
            "maxLength": 32,
            "minLength": 2,
            "type": "string"
          },
          "minItems": 0,
          "type": "array"
        },
        "canonicalization": {
          "additionalProperties": false,
          "properties": {
            "context_keys_included_in_hash": {
              "description": "Subset of allowlisted context keys included in the query_hash.",
              "items": {
                "maxLength": 128,
                "minLength": 1,
                "type": "string"
              },
              "minItems": 0,
              "type": "array",
              "uniqueItems": true
            },
            "json_canonicalization": {
              "description": "Canonical JSON scheme used for query_hash binding.",
              "enum": [
                "JCS",
                "RFC8785",
                "operator-defined"
              ],
              "type": "string"
            },
            "unicode_normalization": {
              "description": "Unicode normalization applied before hashing.",
              "enum": [
                "NFC",
                "NFKC",
                "none"
              ],
              "type": "string"
            }
          },
          "required": [
            "json_canonicalization",
            "unicode_normalization",
            "context_keys_included_in_hash"
          ],
          "type": "object"
        },
        "jwks_uri": {
          "description": "JWKS endpoint for verifying signed responses.",
          "format": "uri",
          "type": "string"
        },
        "required_for_al2": {
          "type": "boolean"
        },
        "supported": {
          "type": "boolean"
        }
      },
      "required": [
        "supported",
        "required_for_al2",
        "algorithms",
        "jwks_uri",
        "canonicalization"
      ],
      "type": "object"
    },
    "transparency": {
      "additionalProperties": false,
      "description": "Transparency signals for AL3+ deployments.",
      "properties": {
        "change_log_uri": {
          "description": "Public change log endpoint for transparency.",
          "format": "uri",
          "type": "string"
        },
        "policy_hash": {
          "description": "Optional hash of current policy/config bundle for immutability references.",
          "type": "string"
        },
        "published_at": {
          "description": "Timestamp of last publication/update.",
          "format": "date-time",
          "type": "string"
        }
      },
      "type": "object"
    }
  },
  "required": [
    "profile",
    "assurance_level",
    "auth",
    "rate_limits",
    "freshness",
    "context_allowlist",
    "signing",
    "recognition_policy"
  ],
  "title": "TSPP TRQP Metadata",
  "type": "object"
}
